# ─────────────────────────────────────────────────────────────────
#  SuperApp Hogar — Variables de entorno
#  Copiar a .env y completar los valores
#  NUNCA commitear el .env (está en .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Base de datos ─────────────────────────────────────────────────
# Para dev local con Docker: usa los valores de docker-compose.yml
DATABASE_URL=postgresql://superapp:superapp_dev@localhost:5432/superapp_hogar

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ── JWT ───────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_EN_PRODUCCION_minimo_32_caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CAMBIAR_EN_PRODUCCION_minimo_32_caracteres_distinto
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=superapp-hogar-dev

# ── Mercado Pago ──────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
MP_WEBHOOK_SECRET=

# ── RENAPER ───────────────────────────────────────────────────────
# Solicitar acceso en: https://www.argentina.gob.ar/renaper
RENAPER_API_KEY=
RENAPER_BASE_URL=https://api.renaper.gob.ar

# ── Anthropic (Mediación IA) ──────────────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Pinecone (Vector DB — Sprint 8) ──────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=superapp-jurisprudencia

# ── Sendgrid (Emails) ────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@superapphogar.com

# ── Twilio (SMS / 2FA) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# ── DocuSign (Contratos — Sprint 4) ──────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_RSA_PRIVATE_KEY=

# ── Web (Next.js) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...
