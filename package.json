{
  "name": "superapp-hogar",
  "private": true,
  "scripts": {
    "start": "node scripts/start-all.mjs",
    "stop": "node scripts/stop-all.mjs",
    "build": "turbo build",
    "dev": "turbo dev",
    "postinstall": "node scripts/fix-dylib-symlinks.mjs 2>/dev/null || true",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @superapp/database studio",
    "db:start": "node scripts/local-db.mjs start",
    "db:stop": "node scripts/local-db.mjs stop",
    "db:status": "node scripts/local-db.mjs status",
    "db:push": "pnpm --filter @superapp/database db:push",
    "db:seed": "pnpm --filter @superapp/database db:seed",
    "setup": "pnpm --filter @superapp/database db:generate && pnpm --filter @superapp/shared build && pnpm --filter @superapp/database build"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "embedded-postgres": "18.3.0-beta.17",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
