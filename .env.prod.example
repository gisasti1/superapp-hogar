# ─── SuperApp Hogar — Variables de PRODUCCIÓN ─────────────────────────────────
# Copiá este archivo a .env.prod y completá los valores.
# NUNCA commitees .env.prod al repo.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=superapp
# Generá una password fuerte: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_password_fuerte_aleatoria
POSTGRES_DB=superapp_hogar

# ── URLs ─────────────────────────────────────────────────────────────────────
# URL pública de la web (HTTPS recomendado)
WEB_URL=https://app.superapphogar.com
# URL pública de la API (HTTPS recomendado)
API_PUBLIC_URL=https://api.superapphogar.com

# ── Puertos host ────────────────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000

# ── JWT — genera secretos únicos ────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=CAMBIAR_minimo_32_chars_aleatorios
JWT_REFRESH_SECRET=CAMBIAR_minimo_32_chars_aleatorios_distintos

# ── Integradores externos (todos opcionales — sin esto la app corre en mock)
# Si NO los configurás, la app sigue funcionando pero los flujos usan datos fake.

# Mercado Pago — https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# RENAPER — https://www.argentina.gob.ar/renaper
RENAPER_API_KEY=

# Anthropic Claude (mediación IA) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Pinecone (vector DB para jurisprudencia)
PINECONE_API_KEY=
PINECONE_INDEX=superapp-jurisprudencia

# Sendgrid (emails transaccionales)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@superapphogar.com

# Twilio (SMS / 2FA)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# DocuSign (firma de contratos)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_RSA_PRIVATE_KEY=

# AWS S3 (uploads de imágenes de propiedades + DNI)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=superapp-hogar-prod
