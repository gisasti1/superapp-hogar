generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  TENANT
  LANDLORD
  REALTOR
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  REJECTED
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  ACTIVE
  TERMINATED
  EXPIRED
}

enum DepositStatus {
  HELD
  PARTIALLY_RELEASED
  RELEASED
  DISPUTED
}

enum PolicyStatus {
  QUOTED
  ACTIVE
  CANCELLED
  EXPIRED
  CLAIMED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  OVERDUE
  // El usuario subió un comprobante de pago manual (transferencia bancaria, etc.)
  // que el propietario o admin tiene que revisar y aprobar.
  RECEIPT_REVIEW
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueCategory {
  PLUMBING       // plomería
  ELECTRICAL     // eléctrica
  APPLIANCES     // electrodomésticos
  STRUCTURAL     // estructura / paredes / techos
  PEST           // plagas
  HEATING_COOLING // calefacción / aire
  COMMON_AREAS   // espacios comunes
  OTHER
}

enum PaymentType {
  RENT
  INSURANCE_PREMIUM
  DEPOSIT
  SERVICE
  MEDIATION_FEE
  SUBSCRIPTION
}

enum CaseCategory {
  REPAIRS
  DEPOSIT_RETURN
  RENT_INCREASE
  NOISE
  EXPENSES
  EARLY_TERMINATION
  OTHER
}

enum CaseStatus {
  OPENED
  WAITING_RESPONSE
  BOTH_STATED
  AI_ANALYZING
  PROPOSAL_READY
  ACCEPTED
  ESCALATED
  RESOLVED
  CLOSED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  REALTOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum BookingStatus {
  REQUESTED
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmploymentType {
  EMPLOYEE          // Relación de dependencia
  SELF_EMPLOYED     // Monotributista / autónomo
  FREELANCER        // Freelancer
  BUSINESS_OWNER    // Empresario / dueño de negocio
  STUDENT           // Estudiante
  RETIRED           // Jubilado / pensionado
  UNEMPLOYED        // Desempleado / busca trabajo
  OTHER
}

enum MaritalStatus {
  SINGLE            // Soltero/a
  IN_RELATIONSHIP   // En pareja
  MARRIED           // Casado/a
  DIVORCED          // Divorciado/a
  WIDOWED           // Viudo/a
  PREFER_NOT_TO_SAY
}

// ─── Prestadores: KYC / matrícula / pagos ─────────────────────────────────

enum ProviderKycStatus {
  NOT_STARTED       // No subió ningún documento todavía
  PENDING           // Subió docs, falta enviar a revisión
  UNDER_REVIEW      // Enviado a admin, esperando revisión
  VERIFIED          // Admin aprobó
  REJECTED          // Admin rechazó (ver rejectionReason)
}

enum ProviderLicenseStatus {
  NOT_REQUIRED      // Categorías que no exigen matrícula (limpieza, mudanzas, etc.)
  PENDING           // Requiere matrícula, todavía no la cargó
  UNDER_REVIEW      // Cargada, esperando revisión admin
  VERIFIED          // Validada
  REJECTED          // Rechazada
  EXPIRED           // Venció — necesita renovar
}

enum ProviderPayoutMethod {
  BANK_TRANSFER     // Transferencia bancaria (CBU)
  CVU               // Cuenta virtual (Mercado Pago, Ualá, etc.)
  MERCADOPAGO       // ID de cuenta MP (para Marketplace MP)
}

enum ProviderDocumentType {
  DNI               // Documento Nacional de Identidad
  CUIT              // CUIT (empresas / autónomos)
  CUIL              // CUIL (empleados en relación de dependencia)
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  // Apodo opcional para mostrar en chats / reseñas en lugar del nombre real.
  // Si está vacío usamos firstName.
  nickname       String?
  // Foto de perfil. Guardamos la URL (local /uploads/avatars/... o S3).
  avatarUrl      String?
  phone          String?
  dni            String?  @unique
  // Dirección particular del usuario (no del inmueble que publica, sino su domicilio)
  // Útil para envío de notificaciones legales, facturación, etc.
  address        String?
  city           String?
  province       String?

  // ─── Datos personales extendidos ──────────────────────────────────────
  dateOfBirth    DateTime?
  nationality    String?
  // ─── Datos profesionales / económicos ─────────────────────────────────
  // Importantes para que un propietario evalúe si el inquilino puede pagar.
  occupation     String?        // "Programador", "Médica", "Profesor", etc.
  employmentType EmploymentType?
  employer       String?        // "Telecom", "Hospital Italiano", "Independiente"
  monthlyIncome  Decimal?       @db.Decimal(12, 2)
  // ─── Datos personales sociales ────────────────────────────────────────
  maritalStatus  MaritalStatus?
  hasPets        Boolean        @default(false)
  smoker         Boolean        @default(false)
  // Bio libre — "me presento" estilo Roomie / OkCupid serio para inquilinos
  bio            String?
  // ─── Contacto de emergencia (opcional pero útil para garantías) ───────
  emergencyContactName  String?
  emergencyContactPhone String?

  // ─── Consentimientos para marketing (Ley AR 25.326 + GDPR-style) ──────
  // El usuario tilda explícitamente. Guardamos también la fecha para auditoría.
  // Sin estos consentimientos, NO se le puede mandar email/SMS de marketing.
  marketingEmailConsent Boolean   @default(false)
  marketingSmsConsent   Boolean   @default(false)
  // Cómo se enteró de la app — útil para medir efectividad de canales
  referralSource        String?   // 'instagram', 'amigo', 'google', 'tv', etc.
  // Última vez que aceptó/cambió consentimientos
  consentUpdatedAt      DateTime?
  role           UserRole @default(TENANT)
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  resetToken     String?  @unique
  resetTokenExp  DateTime?

  // ─── Soft delete / cierre de cuenta ──────────────────────────────────
  // Fecha en que el usuario solicitó dar de baja la cuenta. Si no es null,
  // el usuario no puede iniciar sesión, pero TODA su info histórica
  // (contratos, pagos, reseñas, mensajes) queda intacta en la base.
  // El email se libera renombrándolo a deleted-<uuid>@deleted.local para
  // que pueda volver a registrarse con el mismo mail si quisiera.
  deletedAt        DateTime?
  deletionReason   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  verification   Verification?
  subscription   Subscription?
  sessions       Session[]

  // Relaciones según rol
  properties     Property[]       @relation("OwnerProperties")
  tenantContracts Contract[]      @relation("TenantContracts")
  landlordContracts Contract[]    @relation("LandlordContracts")
  policies       Policy[]
  deposits       Deposit[]
  payments       Payment[]        @relation("PayerPayments")
  receivedPayments Payment[]      @relation("ReceiverPayments")
  openedCases    MediationCase[]  @relation("OpenedCases")
  providerProfile Provider?
  bookings       Booking[]        @relation("UserBookings")
  reviews        Review[]         @relation("UserReviews")
  auditLogs      AuditLog[]
  favorites      Favorite[]
  reportedIssues Issue[]          @relation("ReportedIssues")
  rentalRequestsAsTenant   RentalRequest[]  @relation("RequestsAsTenant")
  rentalRequestsAsLandlord RentalRequest[]  @relation("RequestsAsLandlord")
  authoredContractReviews  ContractReview[] @relation("AuthoredReviews")
  receivedContractReviews  ContractReview[] @relation("ReceivedReviews")
  conversationsAsP1        Conversation[]   @relation("Participant1")
  conversationsAsP2        Conversation[]   @relation("Participant2")
  sentMessages             Message[]
  createdSegments          Segment[]        @relation("CreatedSegments")
  createdCampaigns         Campaign[]       @relation("CreatedCampaigns")
  createdTemplates         ContractTemplate[] @relation("CreatedTemplates")
  agency                   RealEstateAgency?

  // ─── Modo "Particular" ───────────────────────────────────────────────
  // Usuario que NO alquila por la plataforma pero la usa para servicios y
  // para registrar manualmente su contrato y sus pagos. Si está en true,
  // el nav se simplifica y se habilita /my-rental.
  selfManagedRental Boolean        @default(false)
  externalRental    ExternalRental?

  // ─── Presupuesto y pagos mensuales del Particular ─────────────────────
  monthlyBills    MonthlyBill[]    @relation("UserMonthlyBills")
  monthlyPayments MonthlyPayment[] @relation("UserMonthlyPayments")

  // ─── Visitas y co-firmantes ─────────────────────────────────────────
  visitsAsVisitor   PropertyVisit[]  @relation("VisitorVisits")
  visitsAsOwner     PropertyVisit[]  @relation("OwnerVisits")
  contractParties   ContractParty[]  @relation("ContractPartyUser")
  contractInvites   ContractParty[]  @relation("ContractPartyInviter")

  // ─── Recibos de pago ───────────────────────────────────────────────
  receiptsAsPayer    PaymentReceipt[] @relation("ReceiptsAsPayer")
  receiptsAsReceiver PaymentReceipt[] @relation("ReceiptsAsReceiver")

  // ─── Soporte / tickets ─────────────────────────────────────────────
  supportTickets         SupportTicket[]  @relation("SupportTicketUser")
  assignedSupportTickets SupportTicket[]  @relation("SupportTicketAssignee")
  supportMessages        SupportMessage[] @relation("SupportMessageAuthor")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id               String             @id @default(uuid())
  userId           String             @unique
  dni              String?
  dniFrontUrl      String?
  dniBackUrl       String?
  selfieUrl        String?
  renaperResult    Json?
  facialMatchScore Float?
  status           VerificationStatus @default(PENDING)
  rejectedReason   String?
  createdAt        DateTime           @default(now())
  verifiedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

model Property {
  id           String   @id @default(uuid())
  ownerId      String
  address      String
  city         String
  province     String   @default("Buenos Aires")
  rooms        Int
  bathrooms    Int
  squareMeters Float
  monthlyRent  Decimal  @db.Decimal(12, 2)
  expenses     Decimal? @db.Decimal(12, 2)
  currency     String   @default("ARS")
  description  String?
  petsAllowed  Boolean  @default(false)
  amenities    String[] @default([])
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner     User       @relation("OwnerProperties", fields: [ownerId], references: [id])
  contracts Contract[]
  listing   Listing?
  images    PropertyImage[]
  favorites Favorite[]
  issues    Issue[]
  rentalRequests RentalRequest[]
  visits    PropertyVisit[]

  // Índices para los queries más calientes (búsqueda + listings + dashboard)
  @@index([isActive, city])
  @@index([isActive, monthlyRent])
  @@index([ownerId, isActive])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Listing {
  id          String   @id @default(uuid())
  propertyId  String   @unique
  title       String
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Index para el listado público — el most-hit query del marketplace
  @@index([isPublished, createdAt])
  @@map("listings")
}

model ContractTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  // 'RESIDENTIAL' | 'COMMERCIAL' | 'SEASONAL' | 'ROOM'
  type        String   @default("RESIDENTIAL")
  // Texto completo con placeholders: {{landlordName}}, {{tenantName}}, {{address}}, etc.
  content     String   @db.Text
  isBuiltIn   Boolean  @default(false)  // plantillas del sistema — no se pueden borrar
  isActive    Boolean  @default(true)
  createdById String?  // null = plantilla built-in del sistema
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?      @relation("CreatedTemplates", fields: [createdById], references: [id])
  contracts  Contract[]

  @@map("contract_templates")
}

model Contract {
  id            String         @id @default(uuid())
  propertyId    String
  tenantId      String
  landlordId    String
  startDate     DateTime
  endDate       DateTime
  monthlyAmount Decimal        @db.Decimal(12, 2)
  depositAmount Decimal        @db.Decimal(12, 2)
  currency      String         @default("ARS")
  status        ContractStatus @default(DRAFT)
  // Plantilla usada como base
  templateId    String?
  // Texto final del contrato (puede ser la plantilla con datos llenados, o editado manualmente)
  customContent String?        @db.Text
  signedAt      DateTime?
  pdfUrl        String?
  pdfHash       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  template ContractTemplate? @relation(fields: [templateId], references: [id])
  property Property        @relation(fields: [propertyId], references: [id])
  tenant   User            @relation("TenantContracts", fields: [tenantId], references: [id])
  landlord User            @relation("LandlordContracts", fields: [landlordId], references: [id])
  policy   Policy?
  deposit  Deposit?
  payments Payment[]
  cases    MediationCase[]
  signatures ContractSignature[]
  reviews    ContractReview[] @relation("ContractReviews")
  rentalRequest RentalRequest? @relation("OriginatingRequest")
  conversations Conversation[] @relation("ContractConversations")
  rentAdjustments RentAdjustment[]
  parties    ContractParty[]   // co-firmantes invitados de cada lado

  @@map("contracts")
}

model ContractSignature {
  id         String   @id @default(uuid())
  contractId String
  userId     String
  role       String   // 'TENANT' | 'LANDLORD'
  signedAt   DateTime @default(now())
  ipAddress  String?
  docusignEnvelopeId String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
  @@map("contract_signatures")
}

model Policy {
  id            String       @id @default(uuid())
  contractId    String       @unique
  userId        String
  providerId    String
  policyNumber  String       @unique
  status        PolicyStatus @default(ACTIVE)
  monthlyPremium Decimal     @db.Decimal(12, 2)
  coverageAmount Decimal     @db.Decimal(12, 2)
  currency      String       @default("ARS")
  startDate     DateTime
  endDate       DateTime
  pdfUrl        String?
  externalId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  payments Payment[]

  @@map("policies")
}

model Deposit {
  id          String        @id @default(uuid())
  contractId  String        @unique
  userId      String        // dueño del depósito (= inquilino, normalmente)
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("ARS")
  status      DepositStatus @default(HELD)
  yieldEarned Decimal       @db.Decimal(12, 2) @default(0)
  depositedAt DateTime      @default(now())
  releasedAt  DateTime?

  // ─── Custodia / inversión administrada por el admin ───────────────────
  // La plataforma actúa como ventanilla neutral. El admin decide si la plata
  // queda en cuenta espejo, plazo fijo, FCI, etc. Cada depósito tiene su
  // trazabilidad propia (qué inquilino, qué contrato, plazo y dónde está).
  // Si investedIn es null y investedAt es null, está sin invertir.
  investedIn          String?   // "Banco Galicia - PF 30 días", "FCI Pellegrini", etc.
  investedAt          DateTime?
  investmentMaturity  DateTime? // vencimiento del instrumento (plazo de devolución)
  interestRatePct     Decimal?  @db.Decimal(7, 4) // TNA % opcional informativa
  investmentNotes     String?
  // Fecha estimada en que el depósito vuelve al inquilino (= fin de contrato + buffer)
  expectedReleaseDate DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contract      Contract       @relation(fields: [contractId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([status, currency])
  @@index([investedAt])
  @@map("deposits")
}

model LedgerEntry {
  id          String   @id @default(uuid())
  depositId   String
  description String
  debit       Decimal  @db.Decimal(12, 2) @default(0)
  credit      Decimal  @db.Decimal(12, 2) @default(0)
  balance     Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  deposit Deposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

model Payment {
  id           String        @id @default(uuid())
  contractId   String?
  policyId     String?
  payerId      String
  receiverId   String?
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("ARS")
  type         PaymentType
  status       PaymentStatus @default(PENDING)
  dueDate      DateTime
  paidAt       DateTime?
  mpPaymentId  String?       @unique
  mpPreference String?
  failReason   String?
  // Comprobante manual subido por el inquilino (transferencia bancaria, etc.)
  receiptUrl   String?
  receiptNote  String?
  receiptUploadedAt DateTime?
  approvedById String?
  approvedAt   DateTime?
  rejectedReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  contract Contract? @relation(fields: [contractId], references: [id])
  policy   Policy?   @relation(fields: [policyId], references: [id])
  payer    User      @relation("PayerPayments", fields: [payerId], references: [id])
  receiver User?     @relation("ReceiverPayments", fields: [receiverId], references: [id])

  @@map("payments")
}

model MediationCase {
  id          String       @id @default(uuid())
  contractId  String
  openedById  String
  category    CaseCategory
  status      CaseStatus   @default(OPENED)
  summary     String
  createdAt   DateTime     @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime     @updatedAt

  contract   Contract        @relation(fields: [contractId], references: [id])
  openedBy   User            @relation("OpenedCases", fields: [openedById], references: [id])
  statements CaseStatement[]
  evidence   CaseEvidence[]
  proposals  Proposal[]
  resolution Resolution?
  messages   CaseMessage[]

  @@map("mediation_cases")
}

model CaseStatement {
  id        String   @id @default(uuid())
  caseId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  case MediationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, userId])
  @@map("case_statements")
}

model CaseEvidence {
  id        String   @id @default(uuid())
  caseId    String
  userId    String
  fileUrl   String
  fileType  String
  fileName  String
  createdAt DateTime @default(now())

  case MediationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_evidence")
}

model CaseMessage {
  id        String   @id @default(uuid())
  caseId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  case MediationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_messages")
}

model Proposal {
  id             String   @id @default(uuid())
  caseId         String
  legalFramework String
  analysis       String
  suggestion     String
  commitments    String[]
  deadlineDays   Int      @default(15)
  acceptedByTenant   Boolean @default(false)
  acceptedByLandlord Boolean @default(false)
  createdAt      DateTime @default(now())

  case MediationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("proposals")
}

model Resolution {
  id          String   @id @default(uuid())
  caseId      String   @unique
  description String
  isHuman     Boolean  @default(false)
  mediatorId  String?
  resolvedAt  DateTime @default(now())

  case MediationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("resolutions")
}

model Subscription {
  id                  String             @id @default(uuid())
  userId              String             @unique
  plan                SubscriptionPlan   @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  mpSubscriptionId    String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Provider {
  id           String   @id @default(uuid())
  userId       String   @unique
  businessName String
  category     String
  description  String?
  cities       String[]
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  // isVerified = ya pasó KYC + matrícula + admin lo aprobó. Es la bandera
  // que filtra en búsqueda pública. Lo seteamos en true sólo cuando
  // kycStatus=VERIFIED y licenseStatus IN (VERIFIED, NOT_REQUIRED).
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)

  // ─── Datos personales del prestador (separado de User porque puede
  //      ser una empresa: el User es el dueño/contacto, los datos del
  //      prestador son los datos fiscales del negocio) ─────────────────
  documentType    ProviderDocumentType?  // DNI / CUIT / CUIL
  documentNumber  String?                // sin guiones, sólo dígitos
  contactPhone    String?                // teléfono dedicado al negocio
  birthDate       DateTime?              // sólo si documentType=DNI

  // ─── Cuenta para recibir pagos ────────────────────────────────────
  payoutMethod        ProviderPayoutMethod? // BANK_TRANSFER / CVU / MERCADOPAGO
  cbu                 String?               // 22 dígitos
  cvu                 String?               // 22 dígitos (alternativa a CBU)
  bankAlias           String?               // alias bancario (max 20 chars)
  bankName            String?               // nombre del banco (ej "Galicia")
  bankAccountHolder   String?               // titular de la cuenta
  bankAccountHolderId String?               // CUIT/CUIL del titular
  mpAccountId         String?               // ID de cuenta MercadoPago (para Marketplace)
  payoutVerified      Boolean @default(false) // admin verificó que la cuenta es real

  // ─── KYC del prestador (identidad) ────────────────────────────────
  kycStatus           ProviderKycStatus @default(NOT_STARTED)
  idDocumentFrontUrl  String?           // foto/PDF del DNI frente
  idDocumentBackUrl   String?           // foto/PDF del DNI dorso
  selfieUrl           String?           // selfie con DNI en mano (prueba de vida)
  kycSubmittedAt      DateTime?         // cuando lo envió a revisión
  kycReviewedAt       DateTime?
  kycReviewedById     String?           // userId del admin que revisó
  kycRejectionReason  String?           // por qué se rechazó (visible al prestador)

  // ─── Matrícula profesional (gasista, electricista, plomero) ──────
  // Algunas categorías como GAS y ELECTRICIAN exigen matrícula por ley
  // (ENARGAS para gasistas, COPIME/COPITEC para electricistas).
  // Para CLEANER, MOVER, GARDENER lo dejamos NOT_REQUIRED.
  licenseStatus           ProviderLicenseStatus @default(NOT_REQUIRED)
  licenseNumber           String?               // número de matrícula
  licenseAuthority        String?               // ente emisor (ej "ENARGAS")
  licenseDocumentUrl      String?               // foto/PDF de la matrícula
  licenseExpiry           DateTime?             // fecha de vencimiento
  licenseSubmittedAt      DateTime?
  licenseReviewedAt       DateTime?
  licenseReviewedById     String?
  licenseRejectionReason  String?

  // ─── Experiencia y seguros ────────────────────────────────────────
  yearsOfExperience    Int?
  hasInsurance         Boolean @default(false)
  insuranceProvider    String?       // ej "La Caja Seguros"
  insurancePolicyNumber String?
  insuranceExpiry      DateTime?
  emergency24h         Boolean @default(false) // atiende emergencias 24hs

  // ─── Tarifas (informativas, no obligatorias) ──────────────────────
  hourlyRate    Decimal? @db.Decimal(12, 2)
  calloutFee    Decimal? @db.Decimal(12, 2)  // costo de visita / salida
  serviceRadiusKm Int?                       // radio de cobertura desde su base

  // ─── Onboarding ───────────────────────────────────────────────────
  onboardingCompleted Boolean @default(false) // todos los pasos hechos

  // ─── Portfolio (fotos de trabajos anteriores, antes/después) ─────
  // Visible públicamente en el perfil del prestador. Max 12 imágenes.
  portfolioPhotos     String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bookings Booking[]
  reviews  Review[]  @relation("ProviderReviews")

  @@index([kycStatus])
  @@index([licenseStatus])
  @@index([isVerified, isActive])
  // Para filtros del marketplace de servicios (categoría + verificados)
  @@index([category, isActive])
  @@map("providers")
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  providerId  String
  category    String
  description String
  address     String
  status      BookingStatus @default(REQUESTED)
  scheduledAt DateTime?
  completedAt DateTime?
  amount      Decimal?      @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User     @relation("UserBookings", fields: [userId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  review   Review?

  @@map("bookings")
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  reviewerId String
  providerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id])
  reviewer User     @relation("UserReviews", fields: [reviewerId], references: [id])
  provider Provider @relation("ProviderReviews", fields: [providerId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  sentAt    DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, action])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ─── Bloque 1: Favoritos + Issues ────────────────────────────────────────────

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Un usuario no puede favoritear la misma propiedad dos veces
  @@unique([userId, propertyId])
  @@index([userId])
  @@map("favorites")
}

model Issue {
  id           String         @id @default(uuid())
  propertyId   String
  contractId   String?
  reportedById String
  category     IssueCategory  @default(OTHER)
  priority     IssuePriority  @default(MEDIUM)
  status       IssueStatus    @default(OPEN)
  title        String
  description  String
  photos       String[]       @default([])
  // Notas del propietario / técnico sobre la resolución
  resolutionNote String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reportedBy User     @relation("ReportedIssues", fields: [reportedById], references: [id])

  @@index([propertyId, status])
  @@index([reportedById])
  @@map("issues")
}

// ─── Bloque 2: Solicitar alquiler + reseñas mutuas ───────────────────────────

enum RentalRequestStatus {
  PENDING          // recién enviada
  COUNTER_OFFERED  // hay una contraoferta activa esperando respuesta del otro
  APPROVED         // el propietario aceptó, hay que generar el contrato
  REJECTED         // el propietario rechazó
  CANCELLED        // el inquilino canceló su propia solicitud
  EXPIRED          // pasaron N días sin respuesta
  CONVERTED        // se convirtió en contrato
}

model RentalRequest {
  id          String              @id @default(uuid())
  propertyId  String
  tenantId    String
  landlordId  String
  message     String              @db.Text
  // Lo que el inquilino propone — duración y opcionalmente monto distinto al publicado
  proposedStartDate    DateTime?
  proposedMonths       Int?
  proposedMonthlyAmount Decimal? @db.Decimal(12, 2)
  // Contraoferta — última propuesta del otro lado durante la negociación
  counterAmount       Decimal? @db.Decimal(12, 2)
  counterMonths       Int?
  counterStartDate    DateTime?
  counterMessage      String?
  counterByUserId     String?     // quien hizo la última contraoferta
  counterAt           DateTime?
  // Cantidad de idas y vueltas (limit ~6 para evitar ping-pong infinito)
  rounds              Int     @default(0)
  status      RentalRequestStatus @default(PENDING)
  // Respuesta final al aprobar o rechazar
  response    String?             @db.Text
  respondedAt DateTime?
  // Si se generó un contrato a partir de esta solicitud
  contractId  String?             @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   User      @relation("RequestsAsTenant", fields: [tenantId], references: [id])
  landlord User      @relation("RequestsAsLandlord", fields: [landlordId], references: [id])
  contract Contract? @relation("OriginatingRequest", fields: [contractId], references: [id])

  @@index([propertyId, status])
  @@index([tenantId])
  @@index([landlordId])
  @@map("rental_requests")
}

model ContractReview {
  id           String   @id @default(uuid())
  contractId   String
  // Quien escribe la reseña
  authorId     String
  // A quién se le evalúa
  targetId     String
  // Rol del target en el contrato — útil para listar "como propietario soy 4.6"
  targetRole   String   // 'TENANT' | 'LANDLORD'
  rating       Int      // 1..5
  comment      String?  @db.Text
  // Sub-ratings opcionales (cuidado del inmueble, puntualidad de pagos, comunicación, etc.)
  ratingDetails Json?
  createdAt    DateTime @default(now())

  contract Contract @relation("ContractReviews", fields: [contractId], references: [id], onDelete: Cascade)
  author   User     @relation("AuthoredReviews", fields: [authorId], references: [id])
  target   User     @relation("ReceivedReviews", fields: [targetId], references: [id])

  // Cada parte sólo puede escribir UNA reseña por contrato
  @@unique([contractId, authorId])
  @@index([targetId])
  @@map("contract_reviews")
}

// ─── Bloque 3: Chat entre las partes ─────────────────────────────────────────

/**
 * Una conversación es entre 2 usuarios (1:1). En MVP no soportamos grupos.
 * Puede estar opcionalmente vinculada a un contrato o una solicitud de alquiler
 * para contextualizar de qué se habla.
 */
model Conversation {
  id             String   @id @default(uuid())
  participant1Id String
  participant2Id String
  // Vinculaciones opcionales (contexto)
  contractId     String?
  rentalRequestId String?
  // Snapshot del último mensaje — evita un join extra al listar conversaciones
  lastMessageAt  DateTime @default(now())
  lastMessagePreview String? @db.VarChar(140)
  createdAt      DateTime @default(now())

  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id])
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id])
  contract     Contract? @relation("ContractConversations", fields: [contractId], references: [id])
  messages     Message[]

  // 1 conversación por par de participantes (orden no importa pero
  // siempre guardamos participant1 < participant2 lexicográficamente)
  @@unique([participant1Id, participant2Id, contractId])
  @@index([participant1Id, lastMessageAt])
  @@index([participant2Id, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  // Read receipts: hora a la que la contraparte lo vio (null = no leído)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Bloque 4: Actualización de alquiler (ICL / IPC) ──────────────────────────

/**
 * Ajustes periódicos del alquiler según índices oficiales argentinos.
 * - ICL (Índice de Contratos de Locación) = lo que indica la Ley de Alquileres
 *   antes de la DNU 70/2023. Combina IPC + RIPTE.
 * - IPC = Índice de Precios al Consumidor del INDEC (usado tras DNU 70/2023).
 * - CUSTOM = el contrato define una fórmula propia (ej: dólar oficial).
 *
 * Cada ajuste deja registro: monto previo, monto nuevo, índice aplicado,
 * fecha de vigencia. Histórico inmutable para auditoría legal.
 */
enum RentAdjustmentIndex {
  ICL
  IPC
  ICL_IPC_MIX   // 50/50 (algunos contratos lo usan)
  CUSTOM
}

model RentAdjustment {
  id           String              @id @default(uuid())
  contractId   String
  index        RentAdjustmentIndex
  // El multiplicador aplicado (ej: 1.85 = +85% anual)
  multiplier   Decimal             @db.Decimal(8, 4)
  previousAmount Decimal           @db.Decimal(12, 2)
  newAmount    Decimal             @db.Decimal(12, 2)
  // Período de referencia del índice (ej: "abr2025-abr2026")
  periodLabel  String
  // Fecha desde la cual rige el nuevo monto
  effectiveFrom DateTime
  // Snapshot del valor del índice usado (para auditoría)
  indexSnapshot Json?
  appliedAt    DateTime            @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, effectiveFrom])
  @@map("rent_adjustments")
}

// ─── Marketing: segmentos para campañas ──────────────────────────────────────

/**
 * Un segmento es una "audiencia" definida por filtros. Se reusa para campañas.
 * Los filtros se guardan como JSON estructurado y se aplican dinámicamente
 * — el size cambia con el tiempo a medida que se registran nuevos usuarios.
 *
 * Ejemplo: { role: 'TENANT', city: 'Buenos Aires', minIncome: 500000,
 *            hasPets: false, ageMin: 25, ageMax: 45 }
 */
model Segment {
  id          String   @id @default(uuid())
  name        String
  description String?
  // Filtros estructurados — el AdminService los traduce a Prisma where.
  filters     Json
  // Snapshot del último count calculado (para no recalcular en cada list)
  lastCount   Int      @default(0)
  lastCountAt DateTime?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User      @relation("CreatedSegments", fields: [createdById], references: [id])
  campaigns Campaign[]

  @@map("segments")
}

enum CampaignStatus {
  DRAFT       // borrador, no se envió
  SENT        // ya se mandó
  CANCELLED
}

enum CampaignChannel {
  EMAIL
  SMS
}

/**
 * Una campaña apunta a un segmento y manda emails/SMS.
 * Para MVP no soportamos templates ni A/B testing — sólo subject + body.
 */
model Campaign {
  id          String          @id @default(uuid())
  name        String
  channel     CampaignChannel
  subject     String?         // sólo para EMAIL
  body        String          // texto plano o HTML básico
  status      CampaignStatus  @default(DRAFT)
  segmentId   String
  // Estadísticas de envío
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  sentAt      DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  createdBy User    @relation("CreatedCampaigns", fields: [createdById], references: [id])

  @@index([segmentId])
  @@map("campaigns")
}

// ─── Inmobiliaria / Gestora de alquileres ────────────────────────────────────
// Un usuario con role=REALTOR puede crear este perfil para representar
// su agencia. Tiene matrícula CUCICBA/CMCPSI, CUIT y las ciudades donde opera.
// Sus propiedades en Property apuntan directamente a ownerId=agency.userId.

model RealEstateAgency {
  id             String   @id @default(uuid())
  userId         String   @unique

  // ─── Datos de la agencia ─────────────────────────────────────────
  agencyName     String
  cuit           String?                   // CUIT de la persona jurídica
  licenseNumber  String?                   // Matrícula CUCICBA / CMCPSI / provincial
  licenseAuthority String?                 // Organismo emisor, ej "CUCICBA"
  licenseExpiry  DateTime?

  description    String?
  cities         String[]                  // ciudades donde opera
  phone          String?                   // tel. comercial (distinto al del User)
  website        String?
  logoUrl        String?                   // URL de logo subido

  // ─── Estado ────────────────────────────────────────────────────
  isVerified     Boolean  @default(false)  // admin validó matrícula
  isActive       Boolean  @default(true)

  // ─── Contadores (desnormalizados, se actualizan en queries) ─────
  listingCount   Int      @default(0)      // propiedades activas publicadas

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified, isActive])
  @@map("real_estate_agencies")
}

// ─── Contrato externo del usuario "Particular" ────────────────────────────
// Para usuarios que alquilan por fuera de la plataforma pero quieren
// trackear su contrato y sus pagos mensuales acá. No genera obligaciones
// legales en la app — es solo una bitácora personal.
model ExternalRental {
  id              String   @id @default(uuid())
  userId          String   @unique
  // Contraparte (propietario / inmobiliaria)
  landlordName    String
  landlordPhone   String?
  landlordEmail   String?
  landlordCbu     String?
  // Inmueble
  address         String
  city            String
  province        String?
  // Condiciones
  monthlyAmount   Decimal  @db.Decimal(12,2)
  currency        String   @default("ARS")
  depositAmount   Decimal? @db.Decimal(12,2)
  dueDay          Int      @default(10)
  startDate       DateTime
  endDate         DateTime
  // Estado / notas
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        ExternalPayment[]

  @@map("external_rentals")
}

model ExternalPayment {
  id          String   @id @default(uuid())
  rentalId    String
  // Período de cobro, formato "YYYY-MM" — uno por mes
  period      String
  amount      Decimal  @db.Decimal(12,2)
  currency    String   @default("ARS")
  paidAt      DateTime
  method      String?  // 'CASH','TRANSFER','MERCADOPAGO','OTHER'
  receiptUrl  String?
  note        String?
  createdAt   DateTime @default(now())

  rental      ExternalRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@unique([rentalId, period])
  @@index([rentalId, paidAt])
  @@map("external_payments")
}

// ─── Presupuesto mensual del usuario "Particular" ─────────────────────────
// Cada fila es un concepto recurrente (alquiler, expensas, luz, gas, etc.).
// El usuario puede prender/apagar (isEnabled) los items que paga vs. los que
// están a cargo del propietario, y editar el monto cuando llega una factura
// con valor distinto.
model MonthlyBill {
  id        String   @id @default(uuid())
  userId    String
  category  String   // RENT, EXPENSES, ELECTRIC, GAS, WATER, ABL, INTERNET, CABLE, INSURANCE, OTHER
  label     String   // "Alquiler", "EDESUR", "Metrogas"... editable
  amount    Decimal  @db.Decimal(12,2)
  currency  String   @default("ARS")
  dueDay    Int?     // día del mes que vence (opcional)
  isEnabled Boolean  @default(true)
  notes     String?
  sortOrder Int      @default(0)

  // ─── Congelamiento ───────────────────────────────────────────────────
  // Si frozenUntil > now el item NO suma al total del mes. Sirve para
  // pausas temporales (ej: vacaciones, gas en verano que no se usa)
  // sin perder la config del item.
  frozenUntil   DateTime?

  // ─── Medio de pago default + débito automático ───────────────────────
  // CASH | TRANSFER | MERCADOPAGO | CARD | AUTO_DEBIT
  paymentMethod String?
  // Si está en true el sistema asume que el monto se cobra solo (tarjeta,
  // débito automático bancario). El UI lo marca con ⚡ y un futuro cron
  // puede auto-registrar el pago.
  autoDebit     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("UserMonthlyBills", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, isEnabled])
  @@map("monthly_bills")
}

// Snapshot del pago de un mes completo, con el desglose congelado en JSON
// (porque si después editás el monto de luz, no querés pisar los pagos pasados).
model MonthlyPayment {
  id         String   @id @default(uuid())
  userId     String
  period     String   // YYYY-MM
  total      Decimal  @db.Decimal(12,2)
  currency   String   @default("ARS")
  breakdown  Json     // [{ category, label, amount }]
  paidAt     DateTime
  method     String?  // CASH | TRANSFER | MERCADOPAGO | OTHER
  note       String?
  createdAt  DateTime @default(now())

  user       User     @relation("UserMonthlyPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, paidAt])
  @@map("monthly_payments")
}

// ─── Visitas al inmueble ──────────────────────────────────────────────────
enum VisitStatus {
  PROPOSED          // el inquilino propuso fecha/hora — espera al propietario
  COUNTER_PROPOSED  // alguien contrapropuso; espera al otro
  CONFIRMED         // ambas partes acordaron
  REJECTED          // alguien rechazó
  CANCELLED         // alguien canceló después de confirmada
  COMPLETED         // pasó la fecha
}

model PropertyVisit {
  id           String      @id @default(uuid())
  propertyId   String
  // Quien quiere visitar (típicamente el interesado en alquilar)
  visitorId    String
  // Quien tiene que aprobar (propietario o realtor a cargo)
  ownerId      String
  // Última propuesta de fecha/hora — siempre refleja la negociación más reciente
  proposedDate DateTime
  // Quien hizo la última propuesta (PROPOSED / COUNTER_PROPOSED)
  proposedBy   String
  status       VisitStatus @default(PROPOSED)
  message      String?
  // Nº de contraofertas — para evitar ping-pong infinito
  rounds       Int         @default(0)
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  visitor  User     @relation("VisitorVisits", fields: [visitorId], references: [id])
  owner    User     @relation("OwnerVisits",   fields: [ownerId],   references: [id])

  @@index([propertyId, status])
  @@index([visitorId])
  @@index([ownerId])
  @@index([proposedDate])
  @@map("property_visits")
}

// ─── Co-firmantes del contrato ────────────────────────────────────────────
// Cada parte (TENANT o LANDLORD) puede sumar a otra persona al contrato.
// El primary es el que abrió el contrato; los cosigners se invitan por email
// y al aceptar quedan integrados y pueden gestionar igual que el primary.
enum ContractPartyStatus {
  INVITED
  ACCEPTED
  DECLINED
  REMOVED
}

model ContractParty {
  id           String              @id @default(uuid())
  contractId   String
  // Si invitamos a un usuario que ya existe, lo linkeamos; si no, queda solo el email
  userId       String?
  invitedEmail String?
  side         String              // 'TENANT' | 'LANDLORD'
  // PRIMARY = el que abrió el contrato (1 por lado), COSIGNER = invitado
  role         String              @default("COSIGNER")
  invitedById  String
  invitedAt    DateTime            @default(now())
  acceptedAt   DateTime?
  declinedAt   DateTime?
  status       ContractPartyStatus @default(INVITED)
  inviteToken  String              @unique @default(uuid())

  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user      User?    @relation("ContractPartyUser",    fields: [userId],     references: [id])
  invitedBy User     @relation("ContractPartyInviter", fields: [invitedById], references: [id])

  @@unique([contractId, userId])
  @@index([contractId, side])
  @@index([userId])
  @@map("contract_parties")
}

// ─── Comprobantes de pago (recibo NO fiscal) ──────────────────────────────
// Se emite automáticamente cada vez que se confirma un pago en la app,
// independiente del flujo (MP, registro manual, bills mensuales).
// NO va a AFIP — es un recibo civil entre partes con hash sha256 y QR de
// verificación. Vale como prueba del pago.
model PaymentReceipt {
  id           String   @id @default(uuid())
  // Número correlativo legible. Formato: R-YYYYMM-XXXXXXXX
  number       String   @unique

  // Partes — userId si la persona tiene cuenta, snapshot del nombre/DNI siempre
  payerId      String?
  receiverId   String?
  payerName    String
  receiverName String
  payerDni     String?
  receiverDni  String?

  // Origen del pago para trazar al registro original
  // 'CONTRACT_PAYMENT' | 'EXTERNAL_PAYMENT' | 'BILLS_MONTHLY' | 'OTHER'
  sourceType   String
  sourceId     String?

  // Datos del pago
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("ARS")
  paidAt       DateTime
  method       String?  // 'CASH' | 'TRANSFER' | 'MERCADOPAGO' | 'CARD' | 'AUTO_DEBIT' | 'OTHER'
  description  String?
  // Para bills con desglose por categoría
  breakdown    Json?

  // Integridad — sha256 del payload canónico (para verificación pública)
  payloadHash  String   @unique
  emittedAt    DateTime @default(now())

  payer    User? @relation("ReceiptsAsPayer",    fields: [payerId],    references: [id])
  receiver User? @relation("ReceiptsAsReceiver", fields: [receiverId], references: [id])

  @@index([payerId,    emittedAt])
  @@index([receiverId, emittedAt])
  @@index([sourceType, sourceId])
  @@map("payment_receipts")
}

// ─── Soporte / consultas / quejas a la administración ─────────────────────
// Cualquier usuario puede abrir un ticket. El admin lee, contesta y resuelve.
// Es un hilo: cada respuesta es un SupportMessage.
enum SupportTicketStatus {
  OPEN            // recién abierto, sin asignar
  IN_PROGRESS     // admin lo tomó, está respondiendo
  WAITING_USER    // admin contestó y espera datos del usuario
  RESOLVED        // se resolvió (el user puede reabrir si no le sirvió)
  CLOSED          // cerrado definitivo (>30 días sin respuesta o admin cerró)
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id           String                @id @default(uuid())
  userId       String
  // Categoría principal: 'ACCOUNT' | 'PAYMENTS' | 'CONTRACTS' | 'LISTINGS' |
  //                      'SERVICES' | 'TECHNICAL' | 'SUGGESTION' | 'OTHER'
  category     String
  // Sub-tema dentro de la categoría (ver lib/supportTopics en frontend)
  subCategory  String?
  subject      String
  body         String                @db.Text
  status       SupportTicketStatus   @default(OPEN)
  priority     SupportTicketPriority @default(NORMAL)
  // Quién del admin está a cargo (asignación)
  assignedToId String?
  // Notas internas del admin (no las ve el usuario)
  internalNote String?               @db.Text
  // Cuando el admin marca como resuelto
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user       User             @relation("SupportTicketUser",       fields: [userId],       references: [id])
  assignedTo User?            @relation("SupportTicketAssignee",   fields: [assignedToId], references: [id])
  messages   SupportMessage[]

  @@index([userId, createdAt])
  @@index([status, priority])
  @@index([assignedToId, status])
  @@map("support_tickets")
}

model SupportMessage {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  // 'USER' | 'ADMIN' — denormalizado para mostrar fácil quién escribió
  authorRole String
  body       String   @db.Text
  // Adjuntos opcionales (URLs)
  attachments String[] @default([])
  // Si es del admin, hasta que el user no lo lea queda unread
  readByUser Boolean  @default(false)
  readByAdmin Boolean @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation("SupportMessageAuthor", fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
  @@map("support_messages")
}
